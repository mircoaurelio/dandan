VITE_PEER_STUN_URLS=stun:stun.cloudflare.com:3478,stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Optional PeerJS server override. Leave unset to use the default PeerJS cloud settings.
# VITE_PEER_HOST=your-peer-host.example.com
# VITE_PEER_PORT=443
# VITE_PEER_PATH=/peerjs
# VITE_PEER_SECURE=true

# Recommended for reliable play across carrier, CGNAT, and mixed home/mobile networks.
# Include both UDP and TLS/TCP relay urls when your TURN provider supports them.
# VITE_PEER_TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
# VITE_PEER_TURN_USERNAME=your-turn-username
# VITE_PEER_TURN_CREDENTIAL=your-turn-password

# Optional full override if you prefer to provide the entire ICE server array yourself.
# When set, this takes precedence over VITE_PEER_STUN_URLS and VITE_PEER_TURN_*.
# VITE_PEER_ICE_SERVERS_JSON=[{"urls":["stun:stun.cloudflare.com:3478","stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478?transport=udp","turns:turn.example.com:5349?transport=tcp"],"username":"your-turn-username","credential":"your-turn-password"}]
